# ── TOOSII-XD ULTRA · Bot Setup ──────────────────────────────────────────
  # Fill in your values below, then run: node index.js
  # ─────────────────────────────────────────────────────────────────────────

  # Your WhatsApp number — country code + number, no + sign, no spaces
  # Kenya example  : 254712345678
  # Nigeria example: 2348012345678
  OWNER_NUMBER=

  # Your session ID — paste the full TOOSII~... string from the session generator
  # Get one free at: https://toosii-xd-session-generator-woyo.onrender.com/pair
  SESSION_ID=

  # (Optional) URL of your own session generator — leave blank to use the default
  SESSION_URL=
  